# ============================================================
# UEBA LLM Tuning Configuration
# ============================================================

# GCP Project Configuration
GCP_PROJECT_ID=your-gcp-project-id

# GCS Bucket for training data
# Create with: gcloud storage buckets create gs://your-bucket --location=us-central1
GCS_BUCKET=your-ueba-tuning-bucket

# Vertex AI Tuning Service URL
# The Python tuning service endpoint (Cloud Run)
VERTEX_TUNING_SERVICE_URL=https://your-tuning-service.run.app

# ============================================================
# UEBA-specific overrides (optional)
# ============================================================

# UEBA Vertex project (defaults to GCP_PROJECT_ID)
# LLM_UEBA_VERTEX_PROJECT=your-gcp-project-id

# UEBA tuning GCS bucket (defaults to GCS_BUCKET)
# LLM_UEBA_TUNING_GCS_BUCKET=your-ueba-tuning-bucket

# UEBA tuned model version (default: v0)
# LLM_UEBA_TUNED_MODEL_VERSION=v0

# UEBA Endpoint ID (set after tuning completes)
# LLM_UEBA_ENDPOINT_ID=1234567890123456

# ============================================================
# Vertex AI Permissions Required
# ============================================================
# Grant these roles to your service account:
#   roles/aiplatform.tuningExecutor
#   roles/aiplatform.modelAdmin
#   roles/aiplatform.endpointAdmin
#   roles/storage.objectAdmin
#
# Commands:
#   gcloud projects add-iam-policy-binding YOUR_PROJECT \
#     --member="serviceAccount:YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com" \
#     --role="roles/aiplatform.tuningExecutor"
