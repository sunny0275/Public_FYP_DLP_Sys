* text=auto
* eol=lf

# Force text handling for common file types
*.java text
*.ts text
*.tsx text
*.js text
*.jsx text
*.cs text
*.py text
*.json text
*.xml text
*.yml text
*.yaml text
*.md text
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.jar binary
*.exe binary
*.dll binary
*.asar binary
