# =============================================================================
# DLP Platform Environment Configuration Template
# Copy this to .env and fill in your values
# =============================================================================

# Blockchain configuration
DLP_BLOCKCHAIN_ENABLED=true
DLP_BLOCKCHAIN_RPC_URL=http://host.docker.internal:8545
DLP_BLOCKCHAIN_CHAIN_ID=31337
DLP_BLOCKCHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# JWT secret for authentication (generate with: openssl rand -base64 64)
JWT_SECRET=YOUR_JWT_SECRET_HERE

# =============================================================================
# GOOGLE CLOUD / VERTEX AI CONFIGURATION
# =============================================================================

GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/sa.json

VERTEX_ENDPOINT_ID=
VERTEX_MODEL=gemini-2.5-flash

# API Key (from Google AI Studio)
VERTEX_API_KEY=YOUR_VERTEX_API_KEY
API_KEY=YOUR_API_KEY

# =============================================================================
# VERTEX TUNING AUTO-TRIGGER SETTINGS
# =============================================================================

VERTEX_TUNING_GCS_BUCKET=your-tuning-bucket
VERTEX_TUNING_OBJECT_PREFIX=tuning/classification/
VERTEX_TUNING_MIN_EXAMPLES=100

VERTEX_TUNING_PROJECT_ID=your-gcp-project-id
VERTEX_TUNING_LOCATION=us-central1
VERTEX_TUNING_CONTINUAL_TRAINING=true
VERTEX_TUNING_AUTO_DEPLOY=true
VERTEX_TUNING_ENDPOINT_DISPLAY_NAME=dlp-classification-endpoint
VERTEX_TUNING_SEED_JOB_ID=
VERTEX_TUNING_TUNED_MODEL_VERSION=v0
VERTEX_TUNING_PYTHON_STATE_FILE=./tuning-service-python/tuning-jobs-state.json

VERTEX_TUNING_SERVICE_URL=https://your-tuning-service.run.app
VERTEX_TUNING_CALLBACK_URL=http://host.docker.internal:18080/api/internal/endpoint-refresh
INTERNAL_API_KEY=generate-a-secure-random-key

# =============================================================================
# BLIND WATERMARK CONFIGURATION
# =============================================================================
BLIND_WATERMARK_ENABLED=true
BLIND_WATERMARK_SCRIPT_DIR=./backend/s2c-blind-watermark
BLIND_WATERMARK_PYTHON_EXE=python
BLIND_WATERMARK_PROFILE=robust
DLP_KEYMGMT_MASTER_SECRET=YOUR_MASTER_SECRET_HERE
DLP_KEYMGMT_ACTIVE_KEY_ID=v1
DLP_KEYMGMT_KEYRING=YOUR_KEYRING_HERE

# =============================================================================
# UEBA VERTEX AI CONFIGURATION
# =============================================================================
LLM_UEBA_ENABLED=true
LLM_UEBA_VERTEX_PROJECT=your-gcp-project-id
LLM_UEBA_VERTEX_LOCATION=us-central1
LLM_UEBA_MODEL=gemini-2.5-flash
LLM_UEBA_TIMEOUT=15000
LLM_UEBA_FALLBACK=true
LLM_UEBA_CONFIDENCE_THRESHOLD=0.7
LLM_UEBA_ENDPOINT_ID=

# =============================================================================
# UEBA TUNING CONFIGURATION
# =============================================================================
LLM_UEBA_TUNING_ENABLED=true
LLM_UEBA_TUNING_MIN_EXAMPLES=100
LLM_UEBA_TUNING_GCS_BUCKET=your-ueba-tuning-bucket
LLM_UEBA_TUNING_OBJECT_PREFIX=tuning/ueba/
LLM_UEBA_TUNING_PROJECT_ID=your-gcp-project-id
LLM_UEBA_TUNING_LOCATION=us-central1
LLM_UEBA_TUNING_BASE_MODEL=gemini-2.5-flash
LLM_UEBA_TUNING_AUTO_DEPLOY=true
LLM_UEBA_TUNING_CONTINUAL=true
LLM_UEBA_TUNING_AUTO_CRON=0 0 4 * * ?
LLM_UEBA_TUNED_MODEL_VERSION=v0
LLM_UEBA_TUNING_SERVICE_URL=https://your-tuning-service.run.app
LLM_UEBA_TUNING_CALLBACK_URL=http://host.docker.internal:18080/api/internal/endpoint-refresh
